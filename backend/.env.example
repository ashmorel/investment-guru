DATABASE_URL=postgresql+asyncpg://guru:guru@localhost:5433/guru
SECRET_KEY=change-me-long-random
INITIAL_USER_EMAIL=you@example.com
INITIAL_USER_PASSWORD=change-me

# HSBC WMFS unit-price widget gateway headers (public, browser-visible values
# from the widget's own front-end config — not a privileged credential, but
# kept out of source since this is a public repo). Leave empty to disable the
# HSBC ORSO price provider. To find current values: open
# https://www.hsbc.com.hk/orso/tool/wayfoong-multi-funding-system/unit-prices/
# in a browser, open devtools > Network, reload, and inspect the request
# headers of the pensions-pws-fund-prices XHR.
ORSO_HSBC_CLIENT_ID=
ORSO_HSBC_CLIENT_SECRET=
